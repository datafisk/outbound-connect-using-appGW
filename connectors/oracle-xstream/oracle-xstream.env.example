# Oracle XStream CDC Source Connector Configuration
# Copy this to oracle-xstream.env and update with your values

# Connector Configuration
CONNECTOR_NAME="oracle-xstream-source"
TASKS_MAX="1"

# Oracle Database Connection (via Private Link / App Gateway)
# Use the DNS name if created, or the Private Link endpoint
ORACLE_HOSTNAME="oracle.yourdomain.com"  # Or Private Link IP
ORACLE_PORT="1521"
ORACLE_USER="C##GGADMIN"
ORACLE_PASSWORD="Confluent12!"
ORACLE_DBNAME="XE"
ORACLE_SERVICE_NAME="XE"
ORACLE_PDB_NAME="XEPDB1"
ORACLE_OUT_SERVER_NAME="XOUT"

# Table Capture Configuration
# Regex pattern to match tables to capture
TABLE_INCLUDE_LIST="ORDERMGMT[.](ORDER_ITEMS|ORDERS|EMPLOYEES|PRODUCTS|CUSTOMERS|INVENTORIES|PRODUCT_CATEGORIES|CONTACTS|NOTES|WAREHOUSES|LOCATIONS|COUNTRIES|REGIONS)"

# Topic Configuration
TOPIC_PREFIX="oracle"  # Topics will be named: oracle.ORDERMGMT.ORDERS, etc.

# Snapshot Configuration
SNAPSHOT_MODE="initial"           # initial, initial_only, schema_only, or never
SNAPSHOT_FETCH_SIZE="10000"
SNAPSHOT_MAX_THREADS="4"

# Performance Tuning
QUERY_FETCH_SIZE="10000"
MAX_QUEUE_SIZE="65536"
MAX_BATCH_SIZE="16384"
PRODUCER_BATCH_SIZE="204800"
PRODUCER_LINGER_MS="50"
HEARTBEAT_INTERVAL_MS="300000"

# Kafka Cluster Configuration
KAFKA_CLUSTER_ID="lkc-xxxxx"
KAFKA_API_KEY="YOUR_KAFKA_API_KEY"
KAFKA_API_SECRET="YOUR_KAFKA_API_SECRET"
KAFKA_TOPIC="oracle-cdc-data"

# Schema Registry Configuration (Optional - for Avro)
USE_AVRO="true"  # Set to false to use JSON
SCHEMA_REGISTRY_URL="https://psrc-xxxxx.us-east-1.aws.confluent.cloud"
SCHEMA_REGISTRY_API_KEY="YOUR_SR_API_KEY"
SCHEMA_REGISTRY_API_SECRET="YOUR_SR_API_SECRET"

# Confluent Cloud Environment
CONFLUENT_ENVIRONMENT_ID="env-xxxxx"
