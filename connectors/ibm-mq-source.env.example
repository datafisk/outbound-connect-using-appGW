# IBM MQ Configuration Variables
# Copy this to ibm-mq-source.env and fill in your values

# Confluent Cloud Kafka API Credentials
CONFLUENT_API_KEY=your-kafka-api-key
CONFLUENT_API_SECRET=your-kafka-api-secret
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.region.provider.confluent.cloud:9092

# IBM MQ Connection Settings
# Use the Application Gateway private IP (from terraform output: application_gateway_private_ip)
MQ_HOSTNAME=10.0.1.10
MQ_PORT=1414
MQ_TRANSPORT=client

# IBM MQ Queue Manager Settings
MQ_QUEUE_MANAGER=QM1
MQ_CHANNEL=DEV.APP.SVRCONN

# IBM MQ Credentials (Optional)
# Leave empty if your MQ server allows unauthenticated connections
# Recommended when using network-level security (Private Link, VPN, etc.)
MQ_USERNAME=mqadmin
MQ_PASSWORD=your-mq-password

# For unauthenticated connections, set these to empty:
# MQ_USERNAME=
# MQ_PASSWORD=

# JMS Settings
JMS_DESTINATION_NAME=DEV.QUEUE.1
JMS_DESTINATION_TYPE=queue

# Notes:
# - MQ_HOSTNAME should be the Application Gateway private frontend IP
# - This IP will route through Confluent Cloud Private Link to your Azure Application Gateway
# - The Application Gateway will then forward to your actual IBM MQ backend
# - MQ_TRANSPORT is typically "client" for remote connections
# - JMS_DESTINATION_TYPE can be "queue" or "topic"
#
# Security Notes:
# - MQ_USERNAME and MQ_PASSWORD are OPTIONAL if your MQ server allows unauthenticated access
# - This setup uses multiple security layers: Private Link, NSG, and Application Gateway
# - Unauthenticated MQ connections may be acceptable when relying on network-level security
# - However, using credentials provides defense-in-depth (recommended for production)
# - Ensure your MQ server is configured to allow/deny unauthenticated connections as needed
