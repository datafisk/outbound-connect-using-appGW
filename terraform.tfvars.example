# Example terraform.tfvars file
# Copy this to terraform.tfvars and customize as needed

location        = "westeurope"
resource_prefix = "confluent-pl"

# ===================================================================
# Option 1: Create all new resources (default)
# ===================================================================
create_resource_group = true
create_vnet           = true
create_subnets        = true

vnet_address_space  = ["10.0.0.0/16"]
appgw_subnet_prefix = "10.0.1.0/24"

# ===================================================================
# Option 2: Use existing resource group, VNet, and/or subnets
# ===================================================================
# Uncomment and configure to use existing resources:

# Use existing resource group
# create_resource_group        = false
# existing_resource_group_name = "my-existing-rg"

# Use existing VNet
# create_vnet                        = false
# existing_vnet_name                 = "my-existing-vnet"
# existing_vnet_resource_group_name  = "my-vnet-rg"  # If VNet is in different RG

# Use existing subnet
# create_subnets             = false
# existing_appgw_subnet_name = "appgw-subnet"
# Note: Existing AppGW subnet must have private_link_service_network_policies_enabled = false

# IBM MQ Backend Configuration
# Provide IP addresses or FQDNs of your IBM MQ servers
ibm_mq_backend_targets = ["10.0.2.10"]  # List of IP addresses or FQDNs
# ibm_mq_backend_targets = ["mq.example.com"]  # Example using FQDN
# ibm_mq_backend_targets = ["10.0.2.10", "10.0.2.11"]  # Multiple servers

ibm_mq_backend_port  = 1414  # IBM MQ backend port
ibm_mq_frontend_port = 1414  # Frontend listener port (same as backend typically)

appgw_sku = {
  name     = "Standard_v2"
  tier     = "Standard_v2"
  capacity = 2
}

tags = {
  Environment = "dev"
  Purpose     = "confluent-privatelink"
  ManagedBy   = "terraform"
  Owner       = "your-team"
}

# Confluent Cloud Configuration
# Get these from Confluent Cloud Console
confluent_cloud_api_key    = "YOUR_CONFLUENT_API_KEY"
confluent_cloud_api_secret = "YOUR_CONFLUENT_API_SECRET"
confluent_environment_id   = "env-xxxxx"
confluent_cloud_region     = "westeurope"  # Must match Azure location

# Azure Subscription ID
# Get with: az account show --query id -o tsv
azure_subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# TCP Proxy Auto-Configuration (Optional)
# Automatically configure App Gateway for TCP proxy after deployment
# Requires PowerShell with Az module: Install-Module -Name Az -AllowClobber
# And Azure authentication: Connect-AzAccount
# auto_configure_tcp_proxy = true
#
# Alternative: Configure manually via Azure Portal (see TCP-PROXY-SETUP.md)

# ===================================================================
# Confluent Cloud Network Configuration (Optional)
# ===================================================================
# By default, a new network is created. To use existing resources:

# Use existing Confluent Cloud Network (CCN)
# create_confluent_network      = false
# existing_confluent_network_id = "n-xxxxx"

# Use existing Private Link Attachment
# create_private_link_attachment      = false
# existing_private_link_attachment_id = "platt-xxxxx"

# ===================================================================
# DNS Configuration (Optional)
# ===================================================================
# Create a custom DNS record for the egress access point
# This allows you to use a friendly hostname instead of the IP address

# create_dns_record = true
# dns_domain        = "mq.example.com"

# ===================================================================
# IBM MQ Source Connector Configuration (Optional)
# ===================================================================
# Set create_connector = true to automatically deploy the connector
# Set create_connector = false to deploy only infrastructure (for multi-connector setups)
#
# Multi-connector use case:
#   - Deploy infrastructure once with create_connector = false
#   - Add multiple backend pools/routing rules to App Gateway
#   - Deploy each connector separately (see MULTI-CONNECTOR.md)

create_connector = false  # Set to true to deploy IBM MQ connector

# connector_name   = "ibm-mq-source-connector"

# Kafka Cluster Configuration
# kafka_cluster_id  = "lkc-xxxxx"  # Get from Confluent Cloud
# kafka_api_key     = "YOUR_KAFKA_API_KEY"
# kafka_api_secret  = "YOUR_KAFKA_API_SECRET"
# kafka_topic       = "ibm-mq-messages"

# IBM MQ Connection Settings
# The connector will automatically use DNS name (if created) or access point IP
# mq_transport      = "client"
# mq_queue_manager  = "QM1"
# mq_channel        = "DEV.APP.SVRCONN"

# IBM MQ Credentials (Optional)
# mq_username = "mqadmin"
# mq_password = "your-mq-password"

# JMS Settings
# jms_destination_name = "DEV.QUEUE.1"
# jms_destination_type = "queue"

# SSL/TLS Configuration (Optional)
# mq_ssl_cipher_suite          = "TLS_RSA_WITH_AES_128_CBC_SHA256"
# mq_ssl_keystore_location     = "/path/to/keystore.jks"
# mq_ssl_keystore_password     = "keystore-password"
# mq_ssl_truststore_location   = "/path/to/truststore.jks"
# mq_ssl_truststore_password   = "truststore-password"

# ===================================================================
# Oracle Database Provisioning (Optional)
# ===================================================================
# Automatically provision Oracle XE 21c on Azure VM for PoC/testing
# Set provision_oracle_database = true to create Oracle VM with XStream CDC

# provision_oracle_database = false

# SSH Configuration (required if provisioning Oracle)
# oracle_ssh_public_key       = "ssh-rsa AAAA..."  # Or use file() function in .tfvars
# oracle_ssh_private_key_path = "~/.ssh/id_rsa"

# Oracle Database Configuration
# oracle_sys_password = "YourSecurePassword!"  # Oracle SYS/SYSTEM password
# oracle_pdb_name     = "XEPDB1"               # Pluggable database name
# oracle_vm_size      = "Standard_D4s_v3"      # VM size (4 vCPUs, 16 GB RAM)

# Subnet Configuration (for Oracle VM)
# Option 1: Create new subnet (default)
# oracle_create_subnet = true

# Option 2: Use existing subnet (no NSG management)
# oracle_create_subnet      = false
# oracle_existing_subnet_id = "/subscriptions/.../subnets/oracle-subnet"
# oracle_create_nsg         = false  # Skip NSG when using existing subnet

# ===================================================================
# Oracle XStream CDC Connector (Optional)
# ===================================================================
# Deploy Oracle XStream CDC connector to Confluent Cloud
# Requires: kafka_cluster_id, kafka_api_key, kafka_api_secret

# create_oracle_connector = false

# oracle_connector_name = "oracle-xstream-cdc-connector"

# Oracle Connection (automatically uses Access Point IP or DNS)
# oracle_db_user     = "C##GGADMIN"           # XStream admin user
# oracle_db_password = "YourXStreamPassword!" # XStream user password

# Table Capture Configuration
# oracle_table_include_list = "ORDERMGMT[.](ORDERS|CUSTOMERS|PRODUCTS)"
# oracle_topic_prefix       = "oracle"
# oracle_snapshot_mode      = "initial"  # initial, schema_only, or never

# Advanced Configuration (optional)
# oracle_db_name              = "XE"      # CDB name
# oracle_pdb_name             = "XEPDB1"  # PDB name
# oracle_out_server_name      = "XOUT"   # XStream outbound server name
# oracle_snapshot_fetch_size  = "10000"  # Rows per snapshot query

# ===================================================================
# Oracle Backend Configuration (Using Existing Oracle)
# ===================================================================
# If you have an existing Oracle database (not provisioned by Terraform),
# add it to the Application Gateway backend pool:

# oracle_backend_targets = ["10.0.5.10"]  # Oracle DB private IP
# oracle_backend_port    = 1521
# oracle_frontend_port   = 1521

# Note: Provisioned Oracle VM is automatically added to backend pool
